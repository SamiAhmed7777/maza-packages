<?xml version="1.0" encoding="utf-8"?>
<!--
  Chocolatey package for MAZA Core 0.16.3
  Build:  choco pack (from this directory)
  Push:    choco push maza.0.16.3.nupkg --api-key=<key> --source https://push.chocolatey.org/
  Submit PR: https://github.com/chocolatey-community/chocolatey-packages
-->
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>maza</id>
    <version>0.16.3</version>
    <title>MAZA Core</title>
    <authors>MazaCoin</authors>
    <projectUrl>https://mazacoin.org/</projectUrl>
    <iconUrl>https://raw.githubusercontent.com/SamiAhmed7777/maza-packages/main/assets/maza-icon.png</iconUrl>
    <copyright>Copyright 2014-2026 MazaCoin</copyright>
    <licenseUrl>https://opensource.org/licenses/MIT</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <projectSourceUrl>https://github.com/MazaCoin/maza</projectSourceUrl>
    <docsUrl>https://github.com/MazaCoin/maza/blob/master/README.md</docsUrl>
    <bugTrackerUrl>https://github.com/MazaCoin/maza/issues</bugTrackerUrl>
    <tags>maza mazacoin cryptocurrency wallet blockchain bitcoin-fork admin foss cross-platform</tags>
    <summary>MAZA (MazaCoin) full node wallet — a sovereign-tribe cryptocurrency</summary>
    <description><![CDATA[
MAZA Core is the full node software that makes up the backbone of the MAZA network.

MAZA (MazaCoin) is a cryptocurrency created in 2014 focused on providing sovereign
tribes — including the Oglala Sioux — a more independent economy.

This package installs the MAZA Qt desktop wallet and the mazad full node daemon.

Upstream: https://github.com/MazaCoin/maza
]]></description>
    <releaseNotes><![CDATA[
# MAZA 0.16.3

NEW IN MAZA 0.16.3
- Hive Mining ability — purchase bees with MAZA which work on the blockchain to find blocks
- CPU Mining support — MAZA 0.16.3 incorporates the MinotaurX algorithm to allow for
  mining by CPU miners without ASIC equipment. SHA-256 mining support is still enabled
  as well, however ASICBoost is no longer supported with this upgrade.

Binaries downloaded from: https://github.com/MazaCoin/maza/releases/tag/v0.16.3
]]></releaseNotes>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>